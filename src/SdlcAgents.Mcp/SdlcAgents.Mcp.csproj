    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AssemblyName>SdlcAgents.Mcp</AssemblyName>
    <RootNamespace>SdlcAgents.Mcp</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <!-- Official Model Context Protocol C# SDK (maintained with Microsoft) -->
